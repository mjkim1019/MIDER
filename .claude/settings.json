{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "python3 .claude/scripts/auto_manual.py"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "python3 .claude/scripts/log_change.py"
      }
    ],
    "Stop": [
      {
        "command": "bash .claude/scripts/self_check.sh"
      }
    ]
  }
}
