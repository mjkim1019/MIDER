# Mider 환경 변수 설정
# 이 파일을 .env로 복사한 후 값을 입력하세요.
# cp .env.example .env

# ── Azure OpenAI (옵션 1) ──
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── OpenAI 직접 사용 (옵션 2) ──
# MIDER_API_KEY=sk-your-openai-key-here
# MIDER_API_BASE=https://api.openai.com/v1  # 선택적

# 기본 LLM 모델 (Azure 배포명 또는 OpenAI 모델명)
MIDER_MODEL=gpt-4o

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
MIDER_LOG_LEVEL=INFO
