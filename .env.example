# Mider 환경 변수 설정
# 이 파일을 .env로 복사한 후 값을 설정하세요.
# cp .env.example .env

# ──────────────────────────────────────────────
# AICA LLM Gateway (필수)
# ──────────────────────────────────────────────
AICA_API_KEY=your-api-key
AICA_ENDPOINT=http://aica.sktelecom.com:3000

# ──────────────────────────────────────────────
# AICA 선택 설정
# ──────────────────────────────────────────────
# AICA_SSO_SESSION=your-sso-session-token
# AICA_USER_ID=mider_agent # agent_developer

# ──────────────────────────────────────────────
# LLM 모델 (기본: settings.yaml 기준)
# ──────────────────────────────────────────────
# MIDER_MODEL=gpt-5
