{
  "permissions": {
    "allow": [
      "Read(//d/tmp/**)",
      "Bash(python:*)",
      "Bash(taskkill:*)"
    ],
    "additionalDirectories": [
      "\\tmp"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/auto_manual.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/log_change.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/self_check.sh"
          }
        ]
      }
    ]
  }
}
