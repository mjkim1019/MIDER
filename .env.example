# Mider 환경 변수 설정
# 이 파일을 .env로 복사한 후 값을 설정하세요.
# cp .env.example .env

# ──────────────────────────────────────────────
# API Provider 선택 ("openai" 또는 "aica")
# ──────────────────────────────────────────────
API_PROVIDER=openai

# ──────────────────────────────────────────────
# OpenAI / Azure OpenAI (API_PROVIDER=openai 일 때)
# ──────────────────────────────────────────────
# Azure OpenAI (권장)
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# 또는 OpenAI 직접 사용
# OPENAI_API_KEY=sk-your-api-key

# ──────────────────────────────────────────────
# AICA LLM Gateway (API_PROVIDER=aica 일 때)
# ──────────────────────────────────────────────
# AICA_API_KEY=your-api-key
# AICA_ENDPOINT=http://aica.sktelecom.com:3000
# AICA_SSO_SESSION=your-sso-session-token
# AICA_USER_ID=mider_agent

# ──────────────────────────────────────────────
# LLM 모델 (기본: settings.yaml 기준)
# ──────────────────────────────────────────────
# MIDER_MODEL=gpt-5
