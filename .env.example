# Mider 환경 변수 설정
# 이 파일을 .env로 복사한 후 값을 설정하세요.
# cp .env.example .env

# ──────────────────────────────────────────────
# Azure OpenAI (권장)
# ──────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# ──────────────────────────────────────────────
# 또는 OpenAI 직접 사용
# ──────────────────────────────────────────────
# MIDER_API_KEY=sk-your-api-key

# ──────────────────────────────────────────────
# LLM 모델 (기본: settings.yaml 기준)
# ──────────────────────────────────────────────
# MIDER_MODEL=gpt-5

# ──────────────────────────────────────────────
# API Base URL (프록시 사용 시)
# ──────────────────────────────────────────────
# MIDER_API_BASE=https://your-proxy.example.com/v1
